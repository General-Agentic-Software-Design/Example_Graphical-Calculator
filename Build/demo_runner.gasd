/* 
   demo_runner.gasd
   Compliance: gasd-1.1.0.gasd
   Purpose: Formalized Demo Sequence for AI/Human verification
*/

CONTEXT: "Functional Verification"
TARGET: "AI Agent"
NAMESPACE: "org.calculator.demo"

FLOW main_demo_sequence():
    @goal("Demonstrate 100% feature coverage of Backbone.js implementation")
    
    1. ACHIEVE "Arithmetic Verification":
        ACHIEVE click_ac()
        ACHIEVE type_input("7 * 8 + sqrt(16)")
        ACHIEVE click_equals()
        ENSURE result_is("60")

    2. ACHIEVE "Scientific Verification":
        ACHIEVE click_ac()
        ACHIEVE type_input("sin(pi / 2) * 5")
        ACHIEVE click_equals()
        ENSURE result_is("5")

    3. ACHIEVE "Algebraic Solver Verification":
        ACHIEVE click_ac()
        ACHIEVE type_input("x^2 - 5x + 6 = 0")
        ACHIEVE click_solve()
        ENSURE result_is("3, 2")

    4. ACHIEVE "Graphing Verification":
        ACHIEVE click_ac()
        ACHIEVE plot_function("sin(x)")
        ACHIEVE plot_function("x^2")
        ACHIEVE plot_function("cos(x)")
        ENSURE active_tab_is("graph")
        ENSURE canvas_not_empty()

    5. ACHIEVE "Persistence Verification":
        ACHIEVE switch_to_tab("history")
        ACHIEVE select_history_item("x^2 - 5x + 6 = 0")
        ENSURE active_tab_is("calc")
        ENSURE display_is("x^2 - 5x + 6 = 0")

    6. ACHIEVE "UI Robustness Verification":
        ACHIEVE click_ac()
        ENSURE display_is("0")
        ENSURE result_is("0")

    7. PERSIST "demo_result.log" via FileSystem
